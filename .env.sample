DATABASE_URL="DATABASE_URL"

# Required for dashboard/payment security. Use a random string (e.g. 32+ chars).
SESSION_SECRET="your-secret-at-least-16-characters-long"

# Admin panel login credentials (hardcoded via env)
ADMIN_USER_ID="admin"
ADMIN_PASSWORD="change-this-admin-password"

# SendGrid API Key (get from https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY="your-sendgrid-api-key-here"

# Verified sender email address (must be verified in SendGrid)
MAIL_FROM="your-verified-sender@example.com"
